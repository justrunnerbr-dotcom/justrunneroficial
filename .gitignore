# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local product images (served from Supabase Storage in production)
/public/products/

# local staging folder for storage:sync pipeline (uploaded to Supabase Storage, não commitar)
/products/

# Supabase CLI local cache (project link state)
/supabase/.temp/

# local production videos (uploaded to Supabase Storage, não commitar)
/public/videos/
/public/VIdeos/
/public/VIDEOS CATEGORIAS UGC/

# temp de conversão de vídeos
/.tmp/

# fotos UGC de origem (já enviadas pro Supabase Storage em ugc/, não commitar)
/public/FOTOS UGC CATEGORIA/

# criativos locais do gestor de tráfego (lidos por src/app/api/admin/criativos,
# enviados direto pro Meta na criação do anúncio — não commitar)
/gestor-trafego/criativos/imagens/*
/gestor-trafego/criativos/videos/*
!/gestor-trafego/criativos/imagens/.gitkeep
!/gestor-trafego/criativos/videos/.gitkeep
