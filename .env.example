# ─────────────────────────────────────────────────────────────────────────────
# Just Runner Store — Environment Variables
# Copie para .env.local e preencha com os valores reais.
# NUNCA faça commit do .env.local.
# ─────────────────────────────────────────────────────────────────────────────

# ── Site ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://justrunner.com.br

# ── Supabase ──────────────────────────────────────────────────────────────────
# Supabase Dashboard → Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://SEU_REF.supabase.co

# Supabase Dashboard → Project Settings → API → anon / public
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...

# Supabase Dashboard → Project Settings → API → service_role
# ATENÇÃO: nunca prefixar com NEXT_PUBLIC_. Bypassa RLS. Somente server-side.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# ── Yampi / Dooki ─────────────────────────────────────────────────────────────
# Alias da loja (Yampi Dashboard → URL da loja)
NEXT_PUBLIC_YAMPI_ALIAS=

# User-Token — Yampi Dashboard → Configurações → API
YAMPI_API_TOKEN=

# User-Secret-Key — Yampi Dashboard → Configurações → API
YAMPI_SECRET_KEY=

# ── Admin Dashboard ───────────────────────────────────────────────────────────
# Senha de acesso ao /admin. Geração: openssl rand -hex 32
ADMIN_SECRET=

# ── Commerce Brain (Anthropic) ────────────────────────────────────────────────
# console.anthropic.com → API Keys
# Sem esta var, o Brain usa hipóteses de fallback (sistema não quebra).
ANTHROPIC_API_KEY=sk-ant-...

# ── Cron Jobs (Vercel) ────────────────────────────────────────────────────────
# Vercel injeta automaticamente: Authorization: Bearer {CRON_SECRET}
# Geração: openssl rand -hex 32
CRON_SECRET=
