# ─────────────────────────────────────────────────────────────────────────────
# Just Runner Store — Environment Variables
# Copie para .env.local e preencha com os valores reais.
# NUNCA faça commit do .env.local.
# ─────────────────────────────────────────────────────────────────────────────

# ── Site ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://justrunner.com.br

# ── Supabase ──────────────────────────────────────────────────────────────────
# Supabase Dashboard → Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://SEU_REF.supabase.co

# Supabase Dashboard → Project Settings → API → anon / public
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...

# Supabase Dashboard → Project Settings → API → service_role
# ATENÇÃO: nunca prefixar com NEXT_PUBLIC_. Bypassa RLS. Somente server-side.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# ── Yampi / Dooki ─────────────────────────────────────────────────────────────
# Alias da loja (Yampi Dashboard → URL da loja)
NEXT_PUBLIC_YAMPI_ALIAS=

# User-Token — Yampi Dashboard → Configurações → API
YAMPI_API_TOKEN=

# User-Secret-Key — Yampi Dashboard → Configurações → API
YAMPI_SECRET_KEY=

# ── Admin Dashboard ───────────────────────────────────────────────────────────
# Senha digitada no login do /admin
ADMIN_PASSWORD=

# Token aleatório guardado no cookie de sessão (não é a senha). Geração: openssl rand -hex 32
ADMIN_SECRET=

# ── Commerce Brain (Anthropic) ────────────────────────────────────────────────
# console.anthropic.com → API Keys
# Sem esta var, o Brain usa hipóteses de fallback (sistema não quebra).
ANTHROPIC_API_KEY=sk-ant-...

# ── Cron Jobs (Vercel) ────────────────────────────────────────────────────────
# Vercel injeta automaticamente: Authorization: Bearer {CRON_SECRET}
# Geração: openssl rand -hex 32
CRON_SECRET=

# ── Meta Ads (gestor de tráfego, /admin/gestor-trafego) ──────────────────────
# Token de sistema com permissões ads_management, ads_read, pages_read_engagement
# Meta Business Suite → Configurações do negócio → Usuários do sistema
META_ACCESS_TOKEN=

# IDs das contas de anúncio (formato "act_123456789", sem o "act_" também funciona
# dependendo do endpoint) — até 3 contas, a 2ª e 3ª são opcionais
META_AD_ACCOUNT_ID_1=
META_AD_ACCOUNT_ID_2=
META_AD_ACCOUNT_ID_3=

# IDs das páginas do Facebook usadas nos anúncios — até 2, a 2ª é opcional
META_PAGE_ID_1=
META_PAGE_ID_2=

# Pixel do Meta pro site (rastreamento client-side) — opcional
NEXT_PUBLIC_META_PIXEL_ID=
# Segundo pixel opcional (conta de anúncio secundária, silo separado) — se vazio, não dispara
NEXT_PUBLIC_META_PIXEL_ID_2=
